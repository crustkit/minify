{
  "name": "@crustkit/minify",
  "version": "0.1.0",
  "description": "JavaScript and CSS minification. Zero config, great defaults, delightful DX.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "crustkit-minify.*.node",
    "README.md",
    "LICENSE"
  ],
  "napi": {
    "name": "crustkit-minify",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "aarch64-apple-darwin",
        "x86_64-unknown-freebsd"
      ]
    }
  },
  "keywords": [
    "minify",
    "minifier",
    "javascript",
    "css",
    "terser",
    "uglify",
    "compress",
    "crustkit",
    "rust",
    "napi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crustkit/minify"
  },
  "author": "crustkit",
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:ts": "tsup",
    "prepublishOnly": "napi prepublish -t npm && npm run build:ts",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260327.2",
    "terser": "^5.37.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@crustkit/minify-darwin-arm64": "0.1.0",
    "@crustkit/minify-darwin-x64": "0.1.0",
    "@crustkit/minify-freebsd-x64": "0.1.0",
    "@crustkit/minify-linux-arm64-gnu": "0.1.0",
    "@crustkit/minify-linux-arm64-musl": "0.1.0",
    "@crustkit/minify-linux-x64-gnu": "0.1.0",
    "@crustkit/minify-linux-x64-musl": "0.1.0",
    "@crustkit/minify-win32-x64-msvc": "0.1.0"
  }
}
